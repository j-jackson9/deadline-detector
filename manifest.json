{
    "manifest_version": 3,
    "name": "DueFlow",
    "version": "1.0.0",
    "description": "Select dates or deadlines on any webpage and quickly add them to Google Calendar.",
    "permissions": [
        "contextMenus", 
        "scripting",
        "activeTab",
        "storage"
        
    ],
    "background": { 
        "service_worker": "background.js" 
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "48": "due-flow.png",
            "96": "due-flow.png",
            "128": "due-flow.png"
        }
    },
    "icons": {
        "48": "due-flow.png",
        "96": "due-flow.png",
        "128": "due-flow.png"
    }
}